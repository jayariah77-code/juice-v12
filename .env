# ╔══════════════════════════════════════════════════════════╗
  # ║                  Juice v12 — Configuration               ║
  # ║                                                          ║
  # ║  1. Fill in the REQUIRED values below                    ║
  # ║  2. Save the file                                        ║
  # ║  3. Deploy to Heroku / Render / Railway / any panel      ║
  # ║                                                          ║
  # ║  Get your Session ID here:                               ║
  # ║  https://juice-v12-session-generator.onrender.com/pair   ║
  # ╚══════════════════════════════════════════════════════════╝


  # ─── REQUIRED ──────────────────────────────────────────────────────────────────

  # Your WhatsApp number — country code + number, NO + or spaces, NO leading 0
  #
  # ┌─────────────────────────────────────────────────────┐
  # │  Country          Code   Example                    │
  # │  ─────────────────────────────────────────────────  │
  # │  Kenya            254    254712345678               │
  # │  Nigeria          234    2348012345678              │
  # │  South Africa     27     27812345678                │
  # │  Ghana            233    233241234567               │
  # │  Tanzania         255    255712345678               │
  # │  Uganda           256    256712345678               │
  # │  Ethiopia         251    251912345678               │
  # │  USA / Canada     1      12025551234                │
  # │  UK               44     447911123456               │
  # │  India            91     919876543210               │
  # │  Pakistan         92     923001234567               │
  # │  Indonesia        62     6281234567890              │
  # │  Brazil           55     5511912345678              │
  # └─────────────────────────────────────────────────────┘
  OWNER_NUMBER=254753204154

  # Your Session ID from the Session Generator link above
  # It must start with  JUICE~
  SESSION_ID=JUICE~PASTE_YOUR_SESSION_ID_HERE

  # Session Generator link shown in .owner and .botinfo commands
  SESSION_URL=https://juice-v12-session-generator.onrender.com/pair


  # ─── TELEGRAM BOT TOKEN (for .telestick command) ─────────────────────────────
  # Required to use .telestick — paste your Telegram Bot token from @BotFather
  # Get one free at https://t.me/BotFather → /newbot
  # TELEGRAM_BOT_TOKEN=your_own_token_here  ← optional, bot works without this


  # ─── OPTIONAL — AI KEYS ────────────────────────────────────────────────────────
  # The bot works without these — GiftedTech + Pollinations are the default.
  # Only add a key if you want that specific model as a fallback.

  # Anthropic Claude  →  https://console.anthropic.com/
  # ANTHROPIC_API_KEY=sk-ant-...


  # ─── OPTIONAL — IMAGE KEYS ─────────────────────────────────────────────────────
  # The bot has free fallbacks for all image tools.
  # Add keys only if you want higher quality / more requests per day.

  # remove.bg  →  https://www.remove.bg/api
  # REMOVEBG_KEY=your_key_here

  # Clipdrop   →  https://clipdrop.co/apis
  # CLIPDROP_KEY=your_key_here


  # ─── OPTIONAL — SPORTS ────────────────────────────────────────────────────────
  # Football-Data.org free key — improves .epl .laliga .ucl etc.
  # FOOTBALL_DATA_API_KEY=your_key_here


  # ─── OPTIONAL — GIFTED TECH KEY ROTATION ──────────────────────────────────────
  # Add extra GiftedTech API keys for round-robin rotation (avoids rate limits)
  # Format: comma-separated
  # GIFTED_API_KEYS=key1,key2,key3


  # ─── OPTIONAL — AUTO STATUS ───────────────────────────────────────────────────
  # AUTO_VIEW_STATUS=yes      # auto-view all status updates (default: yes)
  # AUTO_LIKE_STATUS=yes      # auto-react to status updates (default: yes)
  # AUTO_LIKE_EMOJI=❤️        # emoji used for auto-react (default: ❤️)
  # AUTO_REPLY_STATUS=no      # auto-reply to status updates (default: no)
  